{
  "name": "erouter",
  "version": "0.1.0",
  "description": "Open-source API gateway and resource aggregator for small study groups, indie dev teams and local communities.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "erouter": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "node --test --import tsx tests/*.test.ts",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "fastify": "^4.28.1",
    "undici": "^6.19.8",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
